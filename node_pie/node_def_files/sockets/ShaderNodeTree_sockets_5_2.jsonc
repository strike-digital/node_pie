// This is a list of the socket types of all nodes
// used for telling whether a node is valid during link drag.
// It contains all of the new and updated nodes in this blender version.
// It can be auto generated using the 'generate socket types file' operator
{
  "bl_version": [
    5,
    2
  ],
  "nodes": {
    "FunctionNodeInputBool": {
      "inputs": [],
      "outputs": [
        "NodeSocketBool"
      ]
    },
    "FunctionNodeInputInt": {
      "inputs": [],
      "outputs": [
        "NodeSocketInt"
      ]
    },
    "FunctionNodeInputMenu": {
      "inputs": [],
      "outputs": [
        "NodeSocketMenu"
      ]
    },
    "FunctionNodeInputVector": {
      "inputs": [],
      "outputs": [
        "NodeSocketVector"
      ]
    },
    "ShaderNodeRaycast": {
      "inputs": [
        "NodeSocketVirtual",
        "NodeSocketVector",
        "NodeSocketFloat"
      ],
      "outputs": [
        "NodeSocketVirtual",
        "NodeSocketVector",
        "NodeSocketFloat"
      ]
    },
    "GeometryNodeInputSceneTime": {
      "inputs": [],
      "outputs": [
        "NodeSocketFloat"
      ]
    },
    "ShaderNodeBsdfPrincipled": {
      "inputs": [
        "NodeSocketVector",
        "NodeSocketFloatFactor",
        "NodeSocketFloatWavelength",
        "NodeSocketFloat",
        "NodeSocketColor",
        "NodeSocketBool",
        "NodeSocketFloatDistance"
      ],
      "outputs": [
        "NodeSocketShader"
      ]
    },
    "ShaderNodeBump": {
      "inputs": [
        "NodeSocketVector",
        "NodeSocketFloatFactor",
        "NodeSocketFloatPixel",
        "NodeSocketFloat"
      ],
      "outputs": [
        "NodeSocketVector"
      ]
    },
    "NodeEvaluateClosure": {
      "inputs": [
        "NodeSocketVirtual",
        "NodeSocketClosure"
      ],
      "outputs": [
        "NodeSocketVirtual"
      ]
    },
    "NodeImplicitConversion": {
      "inputs": [
        "NodeSocketShader",
        "NodeSocketVector",
        "NodeSocketInt",
        "NodeSocketFloat",
        "NodeSocketColor",
        "NodeSocketMenu",
        "NodeSocketBool"
      ],
      "outputs": [
        "NodeSocketShader",
        "NodeSocketVector",
        "NodeSocketInt",
        "NodeSocketFloat",
        "NodeSocketColor",
        "NodeSocketMenu",
        "NodeSocketBool"
      ]
    },
    "NodeJoinBundle": {
      "inputs": [
        "NodeSocketBundle"
      ],
      "outputs": [
        "NodeSocketBundle"
      ]
    }
  }
}